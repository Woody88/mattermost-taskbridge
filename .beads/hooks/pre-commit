#!/usr/bin/env sh
# --- BEGIN BEADS INTEGRATION v1.0.0 ---
# This section is managed by beads. Do not remove these markers.
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  _bd_timeout=${BEADS_HOOK_TIMEOUT:-300}
  if command -v timeout >/dev/null 2>&1; then
    timeout "$_bd_timeout" bd hooks run pre-commit "$@"
    _bd_exit=$?
    if [ $_bd_exit -eq 124 ]; then
      echo >&2 "beads: hook 'pre-commit' timed out after ${_bd_timeout}s — continuing without beads"
      _bd_exit=0
    fi
  else
    bd hooks run pre-commit "$@"
    _bd_exit=$?
  fi
  if [ $_bd_exit -eq 3 ]; then
    echo >&2 "beads: database not initialized — skipping hook 'pre-commit'"
    _bd_exit=0
  fi
  if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v1.0.0 ---

# Inlined lint + format checks (replaces calling `lefthook run pre-commit`).
#
# Why not lefthook? beads owns core.hooksPath = .beads/hooks for its own
# hook shims. lefthook also wants to install hooks at core.hooksPath. The
# two clobber each other:
#   - First we tried `lefthook install` from package.json prepare → it
#     refused, blowing up `bun install` (obsidian-mcp-server-2xp).
#   - Then we tried calling `lefthook run pre-commit` from inside this
#     beads hook → lefthook auto-syncs on every invocation and overwrote
#     this very file with its own shim, banishing the beads block to
#     pre-commit.old. Same conflict, inverted.
#
# Conclusion: lefthook fundamentally cannot share core.hooksPath with
# another tool. So we drop lefthook from the runtime path and inline the
# two checks it was running. lefthook.yml is kept as a config artefact /
# documentation only — nothing executes it. bd's BEGIN/END markers above
# guarantee this section is preserved across `bd hooks install` upgrades.
staged=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -n "$staged" ]; then
  ts_files=$(printf '%s\n' "$staged" | grep -E '\.(ts|tsx|js|jsx)$' || true)
  fmt_files=$(printf '%s\n' "$staged" | grep -E '\.(ts|tsx|js|jsx|json|md)$' || true)
  if [ -n "$ts_files" ]; then
    # shellcheck disable=SC2086
    bunx oxlint $ts_files || exit $?
  fi
  if [ -n "$fmt_files" ]; then
    # shellcheck disable=SC2086
    bunx dprint check --allow-no-files $fmt_files || exit $?
  fi
fi
